# Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Base URL of your deployed app (used to build invite links)
# Local dev: http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional — enables the "Générer avec l'IA" personalized interview
# questions feature on each candidate's page. Get a key at
# https://console.anthropic.com/settings/keys. Leave unset to disable
# the feature (everything else works fine without it).
ANTHROPIC_API_KEY=
